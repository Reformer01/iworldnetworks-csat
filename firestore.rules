
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Check if the user is authenticated and has a corporate email from the correct domain
    function isVerifiedSupervisor() {
      return request.auth != null && 
             request.auth.token.email_verified == true && 
             request.auth.token.email.endsWith('@iworldnetworks.net');
    }

    match /feedbacks/{feedbackId} {
      // Public can only create with basic data validation to ensure data integrity
      // We check for type and presence of required fields defined in backend.json
      allow create: if request.resource.data.customerEmail is string && 
                      request.resource.data.category in ["Reliability", "Support", "Testimonials", "Installation", "Billing"] &&
                      request.resource.data.location in ["Abeokuta", "Ibadan", "Osogbo", "Akure"];
      
      // Only verified supervisors can read (list/get), update, or delete
      allow read, update, delete: if isVerifiedSupervisor();
    }
  }
}
