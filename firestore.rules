
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. PUBLIC FEEDBACK SUBMISSION
    // Explicitly allow ANYONE to create feedback without auth or verification.
    match /feedbacks/{feedbackId} {
      allow create: if true;
      
      // 2. ADMINISTRATIVE ACCESS
      // Only verified supervisors with @iworldnetworks.net emails can read/manage data.
      allow read, list, update, delete: if request.auth != null && 
                                          request.auth.token.email_verified == true && 
                                          request.auth.token.email.endsWith('@iworldnetworks.net');
    }
    
    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
