
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Check if the user is an authenticated supervisor with a verified corporate email
    function isVerifiedSupervisor() {
      return request.auth != null && 
             request.auth.token.email_verified == true && 
             request.auth.token.email.endsWith('@iworldnetworks.net');
    }

    match /feedbacks/{feedbackId} {
      // Public can submit feedback without authentication or verification
      allow create: if true;
      
      // Only verified corporate supervisors can read or manage the feedback
      allow read, update, delete: if isVerifiedSupervisor();
    }
  }
}
