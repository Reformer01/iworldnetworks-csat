
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. PUBLIC FEEDBACK SUBMISSION
    // Unconditionally allow ANYONE to create feedback.
    // This ensures customers can always submit reports regardless of their auth state.
    match /feedbacks/{feedbackId} {
      allow create: if true;
      
      // 2. ADMINISTRATIVE ACCESS
      // Strictly restricted to verified corporate accounts.
      // Must be logged in, email verified, and from @iworldnetworks.net.
      allow read, list, update, delete: if request.auth != null && 
                                          request.auth.token.email_verified == true && 
                                          request.auth.token.email.endsWith('@iworldnetworks.net');
    }
    
    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
// SYNC_TRIGGER: 2024-05-22_01
