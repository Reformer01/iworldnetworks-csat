NEXT_PUBLIC_FIREBASE_API_KEY=replace-with-firebase-web-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=replace-with-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=replace-with-web-app-id

# Optional for AI sentiment analysis. If unset, feedback submission still works.
GEMINI_API_KEY=
# Alternative key name accepted by validate-env.mjs
GOOGLE_API_KEY=

# Required for Sentry error monitoring in production.
# Get from https://sentry.io/settings/<org>/projects/<project>/keys/
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Required for Firebase Admin SDK on Vercel or other non-Google runtimes.
# Do not commit real credentials. Store this value in your hosting provider env vars.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Optional deployment hint for validation. Supported values: vercel, firebase, local.
DEPLOY_TARGET=
