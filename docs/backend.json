
{
  "entities": {
    "Feedback": {
      "title": "Feedback",
      "description": "Customer feedback entry from the public portal with AI analysis and workflow tracking",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string", "format": "email" },
        "serviceDate": { "type": "string", "format": "date", "description": "User-specified date of the experience" },
        "serviceTime": { "type": "string", "description": "User-specified time of the experience" },
        "category": { "type": "string", "enum": ["Reliability", "Support", "Testimonials", "Installation", "Billing"] },
        "servicePlan": { "type": "string", "enum": ["H-Lite", "H-Pro", "H-Max", "H-Custom", "U-Lite", "U-Pro", "U-Max", "U-Custom"] },
        "location": { "type": "string", "enum": ["Abeokuta", "Ibadan", "Osogbo", "Akure"] },
        "ratings": { 
          "type": "object",
          "properties": {
            "stability": { "type": "number" },
            "latency": { "type": "number" },
            "peakPerformance": { "type": "number" },
            "professionalism": { "type": "number" },
            "clarity": { "type": "number" },
            "fcr": { "type": "string", "enum": ["Yes", "No"] },
            "signal": { "type": "number" },
            "punctuality": { "type": "number" },
            "quality": { "type": "number" },
            "explanation": { "type": "number" },
            "accuracy": { "type": "number" },
            "reconnection": { "type": "number" }
          }
        },
        "comment": { "type": "string" },
        "staffName": { "type": "string" },
        "timestamp": { "type": "number", "description": "Background submission unix timestamp" },
        "dateFormatted": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "reviewed", "escalated", "resolved"], "default": "pending" },
        "aiAnalysis": {
          "type": "object",
          "properties": {
            "sentiment": { "type": "string", "enum": ["positive", "neutral", "negative"] },
            "keyThemes": { "type": "array", "items": { "type": "string" } },
            "urgency": { "type": "string", "enum": ["low", "medium", "high"] }
          }
        },
        "referralSource": { "type": "string" },
        "spotlightInterview": { "type": "string", "enum": ["Yes", "No", "Maybe"] },
        "resolutionNotes": { "type": "string" }
      },
      "required": ["customerEmail", "category", "location", "timestamp", "serviceDate"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/feedbacks/{feedbackId}": {
      "schema": "Feedback",
      "description": "Collection of all customer feedback and operational telemetry"
    }
  }
}
