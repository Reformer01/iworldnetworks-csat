
{
  "entities": {
    "Feedback": {
      "title": "Feedback",
      "description": "Customer feedback entry from the public portal",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string", "format": "email" },
        "category": { "type": "string", "enum": ["Reliability", "Support", "Testimonials", "Installation", "Billing"] },
        "servicePlan": { "type": "string" },
        "location": { "type": "string" },
        "ratings": { "type": "object" },
        "comment": { "type": "string" },
        "staffName": { "type": "string", "description": "Name of the helping staff member or technician" },
        "timestamp": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "reviewed", "escalated"] },
        "interviewConsent": { "type": "string", "enum": ["Yes", "No", "Maybe"] }
      },
      "required": ["customerEmail", "category", "timestamp"]
    },
    "Staff": {
      "title": "Staff",
      "description": "Internal support staff member",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "department": { "type": "string", "default": "Customer Support" }
      },
      "required": ["name"]
    },
    "Technician": {
      "title": "Technician",
      "description": "Field technician profile with territory details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "partner": { "type": "string", "description": "Tech territory partner" },
        "region": { "type": "string" },
        "primaryTerritory": { "type": "string" }
      },
      "required": ["name", "region"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/feedbacks/{feedbackId}": {
      "schema": "Feedback",
      "description": "Collection of all customer feedback"
    },
    "/staff/{staffId}": {
      "schema": "Staff",
      "description": "Registry of support staff"
    },
    "/technicians/{techId}": {
      "schema": "Technician",
      "description": "Registry of field technicians"
    }
  }
}
