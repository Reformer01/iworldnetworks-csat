
{
  "entities": {
    "Feedback": {
      "title": "Feedback",
      "description": "Customer feedback entry from the public portal",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string", "format": "email" },
        "category": { "type": "string", "enum": ["Reliability", "Support", "Testimonials", "Installation", "Billing"] },
        "servicePlan": { "type": "string", "enum": ["H-Lite", "H-Pro", "H-Max", "H-Custom", "U-Lite", "U-Pro", "U-Max", "U-Custom"] },
        "location": { "type": "string", "enum": ["Abeokuta", "Ibadan", "Osogbo", "Akure"] },
        "ratings": { 
          "type": "object",
          "properties": {
            "stability": { "type": "number" },
            "latency": { "type": "number" },
            "peakPerformance": { "type": "number" },
            "professionalism": { "type": "number" },
            "clarity": { "type": "number" },
            "fcr": { "type": "string", "enum": ["Yes", "No"] },
            "signal": { "type": "number" },
            "punctuality": { "type": "number" },
            "quality": { "type": "number" },
            "explanation": { "type": "number" },
            "accuracy": { "type": "number" },
            "reconnection": { "type": "number" }
          }
        },
        "comment": { "type": "string" },
        "staffName": { "type": "string" },
        "timestamp": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "reviewed", "escalated"], "default": "pending" },
        "referralSource": { "type": "string" }
      },
      "required": ["customerEmail", "category", "location", "timestamp"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/feedbacks/{feedbackId}": {
      "schema": "Feedback",
      "description": "Collection of all customer feedback"
    }
  }
}
